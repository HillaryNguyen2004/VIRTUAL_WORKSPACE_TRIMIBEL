{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4",
            "memory": 1024,
            "maxDuration": 10,
            "includeFiles": "public/**"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|img|fonts|build|vendor)/(.*)",
            "dest": "/public/$1/$2"
        },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://do-an-chuyen-nganh-rho.vercel.app",
        "APP_KEY": "base64:sMzLrx2RzNEnGfQyWdY0J04T0Iq6DurtuNu+R4dPCV4=",

        "SESSION_DRIVER": "cookie",
        "SESSION_SECURE_COOKIE": "true",
        "SESSION_DOMAIN": ".vercel.app",

        "CACHE_DRIVER": "array",
        "QUEUE_CONNECTION": "sync",
        "LOG_CHANNEL": "stderr",

        "FILESYSTEM_DISK": "s3"
    }
}
